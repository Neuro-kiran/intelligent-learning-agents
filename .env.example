# Application Configuration
APP_NAME=intelligent-learning-agents
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered intelligent learning management system with multi-agent tutoring
ENVIRONMENT=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True
WORKERS=4

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/intelligent_learning
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=False
DATABASE_SSL_MODE=prefer

# Vector Database Configuration (for RAG & Embeddings)
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_TYPE=qdrant
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Redis Configuration (Caching & Session Management)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# LLM Configuration (OpenAI)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MODEL_TUTOR=gpt-4
OPENAI_MODEL_ASSESSMENT=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048
OPENAI_REQUEST_TIMEOUT=30

# Alternative LLM (Anthropic)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Education Domain Configuration
MAX_CONCURRENT_STUDENTS=1000
MAX_AGENTS_PER_STUDENT=5
LESSON_GENERATION_TIMEOUT=60
ASSESSMENT_GENERATION_TIMEOUT=45
ADAPTIVE_LEARNING_ENABLED=True
MULTI_LANGUAGE_SUPPORT=True
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,es,fr,de,zh,ja

# Agent Configuration
AGENT_ORCHESTRATOR_TYPE=langgraph
AGENT_EXECUTION_TIMEOUT=300
AGENT_RETRY_ATTEMPTS=3
AGENT_RETRY_BACKOFF=1.5
TURING_MACHINE_MODE=False

# Learning Paths & Curriculum
CURRICULUM_UPDATE_INTERVAL=86400
ADAPTIVE_PATH_UPDATE_INTERVAL=3600
DIFFICULTY_ADJUSTMENT_THRESHOLD=0.7

# Assessment Configuration
MIN_ASSESSMENT_THRESHOLD=0.6
ASSESSMENT_RETRY_LIMIT=3
AUTO_ASSESSMENT_INTERVAL=86400

# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=True
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# Authentication
ENABLE_JWT_AUTH=True
ENABLE_OAUTH2=False
OAUTH2_PROVIDER=google

# Monitoring & Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/intelligent-learning/app.log
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus Metrics
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# Feature Flags
FEATURE_RAG_ENABLED=True
FEATURE_REAL_TIME_ASSESSMENT=True
FEATURE_ADAPTIVE_PATHS=True
FEATURE_MULTI_AGENT_TUTORING=True
FEATURE_PERSONALIZATION=True
FEATURE_ANALYTICS=True
FEATURE_EXPORTS=True

# Email Configuration (for notifications)
EMAIL_BACKEND=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@intelligentlearning.com
EMAIL_USE_TLS=True

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=/var/data/intelligent-learning
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,txt,pptx,xlsx

# External Services
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# Performance Tuning
CACHE_ENABLED=True
BATCH_PROCESSING_ENABLED=True
BATCH_SIZE=32
OPTIMIZE_DB_QUERIES=True
CONNECTION_POOL_ENABLED=True
